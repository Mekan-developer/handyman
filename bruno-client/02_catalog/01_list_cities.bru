meta {
  name: List Cities
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/v1/client/cities
  body: none
  auth: none
}

headers {
  Accept: application/json
}

docs {
  # List Active Cities

  Public endpoint. Returns active cities sorted by name.
  Use this on the onboarding screen to let the client pick their city.

  **Response 200:**
  ```json
  {
    "data": [
      { "id": 1, "name": "Ашхабад" },
      { "id": 2, "name": "Туркменабат" }
    ]
  }
  ```
}
