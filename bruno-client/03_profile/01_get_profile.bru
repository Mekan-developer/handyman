meta {
  name: Get Profile
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/v1/client/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{client_token}}
}

headers {
  Accept: application/json
}

docs {
  # Get Client Profile

  Returns the authenticated client's profile.

  **Response 200:**
  ```json
  {
    "data": {
      "id": 1,
      "name": "Merdan Annagurdow",
      "phone": "+99361111222",
      "city": { "id": 1, "name": "Ашхабад" }
    }
  }
  ```
}
