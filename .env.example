APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Self-hosted vector basemap. Style URL is shared to the frontend via Inertia.
# Dev: local static style.json + /tiles/{z}/{x}/{y}.pbf route reading storage/maps/tiles.mbtiles — no Docker needed.
# To use tileserver-gl instead, point this at its style URL (e.g. http://localhost:8080/styles/basic-preview/style.json).
TILES_STYLE_URL="/maps/style.json"

# Path to the local .mbtiles file, relative to storage/. Used by the /tiles/{z}/{x}/{y}.pbf route.
MBTILES_PATH=maps/tiles.mbtiles

# Socket.IO bridge (socket-server/) — relays OTP codes to the Flutter SMS-gateway phone.
# Must match PORT / GATEWAY_SECRET in socket-server/.env
SMS_GATEWAY_URL=http://127.0.0.1:3000
SMS_GATEWAY_SECRET=changeme
OTP_TTL_MINUTES=3
