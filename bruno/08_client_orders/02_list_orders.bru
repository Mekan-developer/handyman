meta {
  name: Client — List my orders
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/v1/client/orders
  body: none
  auth: bearer
}

auth:bearer {
  token: {{client_token}}
}

headers {
  Accept: application/json
}

params:query {
  ~status: pending
}

docs {
  # Client — My orders

  Returns paginated list of the authenticated client's orders.
  Optional `status` query filter — uncomment to scope to one of:
  pending, assigned, in_progress, completed, cancelled.
}
