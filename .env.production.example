# =====================================================================
# PRODUCTION ENV TEMPLATE (VPS + nginx)
# Скопируй на сервере в .env.production (или .env) и заполни значения.
# Команда: cp .env.production.example .env  &&  php artisan key:generate
# НЕ коммить заполненный файл — он в .gitignore.
# =====================================================================

APP_NAME="Handyman"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Ashgabat
APP_URL=https://example.tm

# UI по умолчанию — русский (поддерживается ru/tk)
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# --- Логи: в проде только warning и выше, без debug ---
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- База данных (MySQL/PostgreSQL, НЕ sqlite) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=handyman
DB_USERNAME=handyman
DB_PASSWORD=

# --- Сессии / кэш / очереди ---
# Рекомендуется redis; database тоже рабочий вариант.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.example.tm

CACHE_STORE=database
CACHE_PREFIX=

QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# --- Redis (если используешь redis для cache/queue/session) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Real-time: Laravel Reverb (НЕ log!) ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Внутренний хост/порт, на котором слушает reverb:start (за nginx-проксей)
REVERB_HOST=127.0.0.1
REVERB_PORT=8081
REVERB_SCHEME=http
# Публичные параметры для фронта (Echo). HOST — домен WebSocket, проксируемый nginx по wss.
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=ws.example.tm
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# --- Почта (реальный SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@example.tm"
MAIL_FROM_NAME="${APP_NAME}"

# --- Self-hosted vector basemap (tileserver-gl, отдаётся по HTTPS через nginx) ---
TILES_STYLE_URL="https://tiles.example.tm/styles/basic-preview/style.json"

VITE_APP_NAME="${APP_NAME}"
